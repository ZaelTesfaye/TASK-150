CREATE TABLE Rollouts (
    id TEXT NOT NULL PRIMARY KEY,
    configVersionId TEXT NOT NULL,
    canaryPercentage INTEGER NOT NULL DEFAULT 10 CHECK(canaryPercentage BETWEEN 1 AND 100),
    status TEXT NOT NULL DEFAULT 'PENDING' CHECK(status IN ('PENDING', 'CANARY', 'FULL', 'ROLLED_BACK')),
    totalUsers INTEGER NOT NULL DEFAULT 0,
    canaryUsers TEXT NOT NULL DEFAULT '[]',
    createdBy TEXT NOT NULL REFERENCES Users(id),
    createdAt TEXT NOT NULL,
    updatedAt TEXT NOT NULL
);

CREATE INDEX idx_rollouts_status ON Rollouts(status);
CREATE INDEX idx_rollouts_configVersion ON Rollouts(configVersionId);

insertRollout:
INSERT INTO Rollouts(id, configVersionId, canaryPercentage, status, totalUsers, canaryUsers, createdBy, createdAt, updatedAt)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

getRolloutById:
SELECT * FROM Rollouts WHERE id = ?;

getRolloutsByStatus:
SELECT * FROM Rollouts WHERE status = ? ORDER BY createdAt DESC;

getActiveRollout:
SELECT * FROM Rollouts WHERE status IN ('CANARY', 'FULL') ORDER BY createdAt DESC LIMIT 1;

getRolloutByConfigVersion:
SELECT * FROM Rollouts WHERE configVersionId = ? ORDER BY createdAt DESC LIMIT 1;

updateRolloutStatus:
UPDATE Rollouts SET status = ?, updatedAt = ? WHERE id = ?;

updateRollout:
UPDATE Rollouts SET canaryPercentage = ?, status = ?, totalUsers = ?, canaryUsers = ?, updatedAt = ?
WHERE id = ?;
